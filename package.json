{
  "name": "cockpit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A GitHub Copilot canvas extension to build, lint, type-check, test and run JavaScript / Node.js / web apps — and update dependencies without breaking them — from the Copilot app side panel.",
  "license": "MIT",
  "author": "Yohan Lasorsa",
  "keywords": [
    "github-copilot",
    "copilot-extension",
    "canvas",
    "javascript",
    "nodejs",
    "web",
    "vite",
    "npm",
    "pnpm",
    "yarn",
    "bun"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "typecheck": "npm run build",
    "smoke": "node scripts/smoke.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "dev": "astro dev --root docs/site",
    "docs:build": "astro build --root docs/site",
    "docs:preview": "astro preview --root docs/site",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check . && npm run build && npm run smoke && npm run test"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.40.0",
    "@biomejs/biome": "2.5.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "astro": "^6.4.8",
    "sharp": "^0.35.1",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
