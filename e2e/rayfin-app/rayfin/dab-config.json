{
  "$schema": "https://github.com/Azure/data-api-builder/releases/latest/download/dab.draft.schema.json",
  "data-source": {
    "database-type": "mssql",
    "connection-string": "@env('RAYFIN_DAB_CONNECTION_STRING')"
  },
  "runtime": {
    "rest": { "enabled": true, "path": "/api/rest" },
    "graphql": { "enabled": true, "path": "/api/graphql" }
  },
  "entities": {
    "User": {
      "source": { "object": "dbo.Users", "type": "table" },
      "permissions": [
        { "role": "admin", "actions": ["create", "read", "update", "delete"] },
        { "role": "member", "actions": ["read"] }
      ],
      "relationships": {
        "projects": {
          "cardinality": "many",
          "target.entity": "Project",
          "source.fields": ["id"],
          "target.fields": ["ownerId"]
        }
      }
    },
    "Category": {
      "source": { "object": "dbo.Categories", "type": "table" },
      "permissions": [
        { "role": "admin", "actions": ["create", "read", "update", "delete"] },
        { "role": "member", "actions": ["read"] }
      ]
    },
    "Project": {
      "source": { "object": "dbo.Projects", "type": "table" },
      "permissions": [
        { "role": "admin", "actions": ["create", "read", "update", "delete"] },
        { "role": "member", "actions": ["create", "read", "update"] }
      ],
      "relationships": {
        "owner": {
          "cardinality": "one",
          "target.entity": "User",
          "source.fields": ["ownerId"],
          "target.fields": ["id"]
        },
        "todos": {
          "cardinality": "many",
          "target.entity": "Todo",
          "source.fields": ["id"],
          "target.fields": ["projectId"]
        }
      }
    },
    "Todo": {
      "source": { "object": "dbo.Todos", "type": "table" },
      "permissions": [
        { "role": "admin", "actions": ["create", "read", "update", "delete"] },
        { "role": "member", "actions": ["create", "read", "update", "delete"] }
      ],
      "relationships": {
        "project": {
          "cardinality": "one",
          "target.entity": "Project",
          "source.fields": ["projectId"],
          "target.fields": ["id"]
        },
        "assignee": {
          "cardinality": "one",
          "target.entity": "User",
          "source.fields": ["assigneeId"],
          "target.fields": ["id"]
        }
      }
    },
    "Tag": {
      "source": { "object": "dbo.Tags", "type": "table" },
      "permissions": [
        { "role": "admin", "actions": ["create", "read", "update", "delete"] },
        { "role": "member", "actions": ["read"] }
      ]
    },
    "Comment": {
      "source": { "object": "dbo.Comments", "type": "table" },
      "permissions": [
        { "role": "admin", "actions": ["create", "read", "update", "delete"] },
        { "role": "member", "actions": ["create", "read"] }
      ],
      "relationships": {
        "todo": {
          "cardinality": "one",
          "target.entity": "Todo",
          "source.fields": ["todoId"],
          "target.fields": ["id"]
        },
        "author": {
          "cardinality": "one",
          "target.entity": "User",
          "source.fields": ["authorId"],
          "target.fields": ["id"]
        }
      }
    }
  }
}
